# Netlify Cache Headers
# Updated: Build10.15 (2026-02-10)
# NOTE: Redirects are in _redirects file (NOT here)
# Build10.15: Removed /*.js wildcard that was overriding specific no-cache rules
# Root-level JS files (build-version.js, sw.js) must never be cached
# Vendor JS under /assets/ is covered by /assets/* rule (1 year cache)

# CRITICAL: build-version.js must NEVER be cached
# This is the version source of truth — stale cache = wrong version displayed
/build-version.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# sw.js must also never be cached (controls app update detection)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Cache static assets for 1 year (immutable — fingerprinted filenames)
# This covers /assets/vendor/react.min.js, react-dom.min.js, and all images
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache CSS for 1 week
/*.css
  Cache-Control: public, max-age=604800

# Build10.15: REMOVED /*.js wildcard — it was overriding build-version.js and sw.js
# no-cache rules. No root-level JS files need week-long caching.
# Vendor JS is cached via /assets/* rule above.

# Cache HTML for 5 minutes (frequent updates)
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Cache root for 5 minutes
/
  Cache-Control: public, max-age=300, must-revalidate
